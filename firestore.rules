rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function authEmail() {
      return isAuthenticated() ? request.auth.token.email : '';
    }

    function authEmailLower() {
      return authEmail().lower();
    }

    function isBootstrapAdmin() {
      return isAuthenticated() && authEmailLower() in [
        'ceo@usglatam.com',
        'yuri@megalopolisms.com',
        'admin@miamialliance3pl.com'
      ];
    }

    function userDocPath(uid) {
      return /databases/$(database)/documents/users/$(uid);
    }

    function userRole(uid) {
      return exists(userDocPath(uid)) ? get(userDocPath(uid)).data.role : null;
    }

    function myRole() {
      return isAuthenticated() ? userRole(request.auth.uid) : null;
    }

    function isAdmin() {
      return isBootstrapAdmin() || myRole() == 'admin';
    }

    function isStaff() {
      return isBootstrapAdmin() || myRole() in ['admin', 'employee'];
    }

    function isJorge() {
      return authEmailLower() == 'ceo@usglatam.com';
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function pendingInvitePath(email) {
      return /databases/$(database)/documents/pending_invites/$(email);
    }

    function hasPendingInviteForEmail(email) {
      return exists(pendingInvitePath(email));
    }

    function pendingInviteRole(email) {
      return hasPendingInviteForEmail(email) ? get(pendingInvitePath(email)).data.role : null;
    }

    function canSelfCreateUserWithRole(role, emailLower) {
      return role == 'customer'
        || (role == 'admin' && isBootstrapAdmin())
        || (
          role in ['employee', 'admin']
          && hasPendingInviteForEmail(emailLower)
          && pendingInviteRole(emailLower) == role
        );
    }

    function canSelfUpdateUser() {
      return request.resource.data.role == resource.data.role
        && request.resource.data.email == resource.data.email;
    }

    // Users collection
    match /users/{userId} {
      allow read: if isAuthenticated() && (isOwner(userId) || isStaff());
      allow create: if isAuthenticated()
        && userId == request.auth.uid
        && request.resource.data.email is string
        && request.resource.data.role in ['customer', 'employee', 'admin']
        && request.resource.data.email.lower() == authEmailLower()
        && canSelfCreateUserWithRole(
          request.resource.data.role,
          request.resource.data.email.lower()
        );
      allow update: if isAdmin() || (isOwner(userId) && canSelfUpdateUser());
      allow delete: if isAdmin();
    }

    // Shipments collection
    match /shipments/{shipmentId} {
      allow read: if isAuthenticated() && (resource.data.user_id == request.auth.uid || isStaff());
      allow create: if isAuthenticated();
      allow update: if isStaff() || resource.data.user_id == request.auth.uid;
      allow delete: if isAdmin();
    }

    // Inventory collection
    match /inventory/{itemId} {
      allow read: if isAuthenticated() && (resource.data.user_id == request.auth.uid || isStaff());
      allow create: if isAuthenticated();
      allow update: if isStaff() || resource.data.user_id == request.auth.uid;
      allow delete: if isAdmin();
    }

    // Invoices collection
    match /invoices/{invoiceId} {
      allow read: if isAuthenticated() && (resource.data.customer_id == request.auth.uid || isStaff());
      allow create: if isStaff();
      allow update: if isStaff();
      allow delete: if isAdmin();
    }

    // Storage snapshots
    match /storage_snapshots/{snapshotId} {
      allow read: if isStaff();
      allow write: if isStaff();
    }

    // Billable events
    match /billable_events/{eventId} {
      allow read: if isAuthenticated() && (resource.data.customer_id == request.auth.uid || isStaff());
      allow write: if isStaff();
    }

    // Pickup/Delivery Requests
    match /pickup_requests/{requestId} {
      allow read: if isAuthenticated() && (resource.data.user_id == request.auth.uid || isStaff());
      allow create: if isAuthenticated();
      allow update: if isStaff();
      allow delete: if isAdmin();
    }

    // Quote Requests — submitted from public quote calculator and contact forms
    match /quote_requests/{requestId} {
      allow read: if isStaff();
      allow create: if true; // Public submissions (no auth required)
      allow update: if isStaff();
      allow delete: if isAdmin();
    }

    // BOL Documents — uploaded Bills of Lading and Shipping Labels
    match /bol_documents/{docId} {
      allow read: if isAuthenticated() && (resource.data.user_id == request.auth.uid || isStaff());
      allow create: if isAuthenticated();
      allow update: if isStaff();
      allow delete: if isAdmin();
    }

    // Activity Log — daily warehouse task entries for activity-based billing
    match /activity_log/{entryId} {
      allow read: if isAuthenticated() && (resource.data.customer_id == request.auth.uid || isStaff());
      allow create: if isStaff();
      allow update: if isStaff();
      allow delete: if isAdmin();
    }

    // Cargo Items — individual pallet/box tracking with unique IDs
    match /cargo_items/{itemId} {
      allow read: if isAuthenticated() && (resource.data.user_id == request.auth.uid || isStaff());
      allow create: if isAuthenticated();
      allow update: if isStaff() || resource.data.user_id == request.auth.uid;
      allow delete: if isAdmin();
    }

    // Column labels — ONLY Jorge can rename columns
    match /settings/column_labels {
      allow read: if isStaff();
      allow write: if isJorge();
    }

    // Settings (admin only write, staff read)
    match /settings/{settingId} {
      allow read: if isStaff();
      allow write: if isAdmin();
    }

    // Invites
    match /invites/{inviteId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin();
      allow update: if isAuthenticated();
      allow delete: if isAdmin();
    }

    // Pending invites — used during signup to auto-assign roles
    match /pending_invites/{email} {
      allow read: if isAdmin() || (isAuthenticated() && authEmailLower() == email.lower());
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin() || (isAuthenticated() && authEmailLower() == email.lower());
    }
  }
}
