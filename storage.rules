rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function isAuthenticated() {
      return request.auth != null;
    }

    function isStaff() {
      return isAuthenticated() &&
        firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role in ['admin', 'employee'];
    }

    match /pickup_documents/{userId}/{allPaths=**} {
      allow read, write: if isAuthenticated() && (request.auth.uid == userId || isStaff());
    }

    match /labels/{userId}/{shipmentId}/{fileName} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isStaff());
      allow write: if isStaff();
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
