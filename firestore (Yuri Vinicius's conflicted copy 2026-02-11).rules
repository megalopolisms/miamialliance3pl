rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // =========================================================================
    // Helpers
    // =========================================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function authEmail() {
      return request.auth.token.email;
    }

    function authEmailLower() {
      return authEmail() != null ? authEmail().lower() : null;
    }

    // Bootstrap admin emails (used before Firestore roles exist)
    function isBootstrapAdmin() {
      return isAuthenticated() && authEmailLower() in [
        'ceo@usglatam.com',
        'yuri@megalopolisms.com'
      ];
    }

    function userDocPath(uid) {
      return /databases/$(database)/documents/users/$(uid);
    }

    function userRole(uid) {
      return exists(userDocPath(uid)) ? get(userDocPath(uid)).data.role : null;
    }

    function myRole() {
      return isAuthenticated() ? userRole(request.auth.uid) : null;
    }

    function isAdmin() {
      return isBootstrapAdmin() || myRole() == 'admin';
    }

    function isStaff() {
      return isBootstrapAdmin() || myRole() in ['admin', 'employee'];
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function pendingInvitePath(email) {
      return /databases/$(database)/documents/pending_invites/$(email);
    }

    function hasPendingInviteForEmail(email) {
      return exists(pendingInvitePath(email));
    }

    function pendingInviteRole(email) {
      return hasPendingInviteForEmail(email)
        ? get(pendingInvitePath(email)).data.role
        : null;
    }

    function canSelfCreateUserWithRole(role, emailLower) {
      // Customers can always create their own profile.
      // Elevated roles require either:
      // - a bootstrap admin email, or
      // - a matching pending_invite
      return role == 'customer'
        || (role == 'admin' && isBootstrapAdmin())
        || (
          role in ['employee', 'admin']
          && hasPendingInviteForEmail(emailLower)
          && pendingInviteRole(emailLower) == role
        );
    }

    function canSelfUpdateUser() {
      // Prevent privilege escalation: role/email must not change via self-update.
      return request.resource.data.role == resource.data.role
        && request.resource.data.email == resource.data.email;
    }

    // =========================================================================
    // Collections
    // =========================================================================

    // Users collection
    match /users/{userId} {
      allow read: if isAuthenticated() && (isOwner(userId) || isStaff());
      allow create: if isAuthenticated()
        && userId == request.auth.uid
        && request.resource.data.email is string
        && request.resource.data.role in ['customer', 'employee', 'admin']
        && request.resource.data.email.lower() == authEmailLower()
        && canSelfCreateUserWithRole(
          request.resource.data.role,
          request.resource.data.email.lower()
        );

      allow update: if isAuthenticated() && (isAdmin() || (isOwner(userId) && canSelfUpdateUser()));
      allow delete: if isAdmin();
    }

    // Shipments collection
    match /shipments/{shipmentId} {
      allow read: if isAuthenticated() && (resource.data.user_id == request.auth.uid || isStaff());
      allow create: if isAuthenticated() && (
        isStaff()
        || (
          request.resource.data.user_id == request.auth.uid
          && request.resource.data.status == 'pending'
        )
      );

      allow update: if isAuthenticated() && (
        isStaff()
        || (
          resource.data.user_id == request.auth.uid
          && request.resource.data.user_id == resource.data.user_id
          && request.resource.data.status == resource.data.status
        )
      );
      allow delete: if isAdmin();
    }

    // Inventory collection
    match /inventory/{itemId} {
      allow read: if isAuthenticated() && (resource.data.user_id == request.auth.uid || isStaff());
      allow create: if isAuthenticated() && (isStaff() || request.resource.data.user_id == request.auth.uid);

      allow update: if isAuthenticated() && (
        isStaff()
        || (
          resource.data.user_id == request.auth.uid
          && request.resource.data.user_id == resource.data.user_id
        )
      );
      allow delete: if isAdmin();
    }

    // Invoices collection
    match /invoices/{invoiceId} {
      allow read: if isAuthenticated() && (resource.data.customer_id == request.auth.uid || isStaff());
      allow create: if isStaff();
      allow update: if isStaff();
      allow delete: if isAdmin();
    }

    // Storage snapshots
    match /storage_snapshots/{snapshotId} {
      allow read, write: if isStaff();
    }

    // Billable events
    match /billable_events/{eventId} {
      allow read: if isAuthenticated() && (resource.data.customer_id == request.auth.uid || isStaff());
      allow write: if isStaff();
    }

    // Settings (admin only write, staff read)
    match /settings/{settingId} {
      // Pricing is needed by portal UX; keep other settings staff-only.
      allow read: if isAuthenticated() && (isStaff() || settingId == 'pricing');
      allow write: if isAdmin();
    }

    // Pending invites: created by admins, consumed by invitee (read+delete).
    match /pending_invites/{email} {
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow read, delete: if isAdmin() || (isAuthenticated() && authEmailLower() == email);
    }

    // Admin dashboards / ops collections (write via server/admin SDK only)
    match /chat_logs/{logId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /escalations/{escId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Backward-compatibility: legacy invites collection (deprecated).
    match /invites/{inviteId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
  }
}
